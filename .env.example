# Copy this file to .env and fill in your Alpaca paper trading credentials.
# Never commit .env to version control.
#
# Get your keys at: https://app.alpaca.markets → Paper Trading → API Keys

ALPACA_API_KEY=your_paper_api_key_here
ALPACA_SECRET_KEY=your_paper_secret_key_here

# Optional: Telegram alerts
# Create a bot via @BotFather, then get your chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: Perplexity API — enables pre-market AI research (ai.enable_research: true)
# Get your key at: https://www.perplexity.ai → Settings → API
PERPLEXITY_API_KEY=

# Optional: Anthropic API — enables Claude signal approval (ai.enable_claude_filter: true)
# Get your key at: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=
